# GitHub connector
GITHUB_TOKEN=your_github_pat_here
GITHUB_OWNER=rawdash
GITHUB_REPO=rawdash

# Turso storage (optional — defaults to local file:rawdash.db)
# Set these to point at a remote Turso database for deployment
# TURSO_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Server port (optional — defaults to 8080)
# PORT=8080
