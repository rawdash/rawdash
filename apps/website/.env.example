# Marketing content feed (RAW-371). See docs/CONTENT_FEED.md.
#
# Build token for the cloud content feed. When unset, the build skips the
# /blog, /integrations, /compare, and /alternatives content section gracefully
# (expected for local docs and outside-contributor builds).
CONTENT_FEED_TOKEN=

# Optional override for the feed endpoint URL.
# Defaults to https://cloud.rawdash.dev/api/content-feed
# CONTENT_FEED_URL=
