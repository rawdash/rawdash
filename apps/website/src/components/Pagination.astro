---
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

const { pagination } = Astro.locals.starlightRoute as StarlightRouteData;
const { prev, next } = pagination;
---

{
  (prev || next) && (
    <nav class="pagination-nav" aria-label="Page navigation">
      <div class="pagination-links">
        {prev && (
          <a href={prev.href} class="pagination-link pagination-link--prev" rel="prev">
            <span class="pagination-link__direction">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
              </svg>
              Previous
            </span>
            <span class="pagination-link__title">{prev.label}</span>
          </a>
        )}
        {next && (
          <a href={next.href} class="pagination-link pagination-link--next" rel="next">
            <span class="pagination-link__direction">
              Next
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m9 18 6-6-6-6" />
              </svg>
            </span>
            <span class="pagination-link__title">{next.label}</span>
          </a>
        )}
      </div>
    </nav>
  )
}

<style>
  .pagination-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .pagination-links {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .pagination-link {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    text-decoration: none;
    flex: 1;
    min-width: 0;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    max-width: 48%;
  }

  .pagination-link:hover {
    border-color: var(--sl-color-accent);
    background-color: color-mix(in srgb, var(--sl-color-accent) 6%, transparent);
  }

  .pagination-link--next {
    align-items: flex-end;
    margin-left: auto;
  }

  .pagination-link--prev {
    align-items: flex-start;
  }

  .pagination-link__direction {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--sl-text-xs);
    font-weight: 500;
    color: var(--sl-color-accent-high);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pagination-link__title {
    font-size: var(--sl-text-base);
    font-weight: 600;
    color: var(--sl-color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
</style>
