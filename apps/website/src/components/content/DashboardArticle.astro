---
import { render } from 'astro:content';
import { connectors as allConnectors } from '../../generated/connectors';
import type { ContentEntry } from '../../lib/content';
import CloudCta from '../site/CloudCta.astro';
import RelatedPages from './RelatedPages.astro';

interface Props {
  entry: ContentEntry;
  sectionLabel: string;
  basePath: string;
}

const { entry, sectionLabel, basePath } = Astro.props;
const { data } = entry;

const { Content } = await render(entry);

const connectorsById = new Map(allConnectors.map((c) => [c.id, c]));
const connectors = data.connectors.map((id) => ({
  id,
  match: connectorsById.get(id) ?? null,
}));

const date = data.publishedAt ?? data.updatedAt;
const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="content-article-hero">
  <div class="content-article-hero-inner">
    <nav class="content-breadcrumb" aria-label="Breadcrumb">
      <a href={basePath}>{sectionLabel}</a>
      <span class="content-breadcrumb__separator" aria-hidden="true">/</span>
      <span class="content-breadcrumb__current" aria-current="page">
        {data.title}
      </span>
    </nav>

    <header class="content-article-header">
      <h1>{data.title}</h1>
      <div class="content-article-meta">
        {
          date && (
            <time datetime={date.toISOString()}>{dateFmt.format(date)}</time>
          )
        }
      </div>
    </header>
  </div>
</div>

<article class="content-article">
  {
    connectors.length > 0 && (
      <section class="dashboard-connectors" aria-label="Connectors">
        <p class="section-label">Connectors</p>
        <ul class="dashboard-connector-list">
          {connectors.map(({ id, match }) =>
            match ? (
              <li>
                <a class="dashboard-connector" href={match.href}>
                  <img
                    src={match.iconPath}
                    alt={`${match.name} logo`}
                    width="24"
                    height="24"
                    loading="lazy"
                  />
                  <span>{match.name}</span>
                </a>
              </li>
            ) : (
              <li>
                <span class="dashboard-connector dashboard-connector-plain">
                  {id}
                </span>
              </li>
            ),
          )}
        </ul>
      </section>
    )
  }

  <div class="content-prose">
    <Content />
  </div>

  {
    data.faq.length > 0 && (
      <section class="dashboard-faq" aria-labelledby="dashboard-faq-heading">
        <h2 id="dashboard-faq-heading">Frequently asked questions</h2>
        <dl>
          {data.faq.map((item) => (
            <div class="dashboard-faq-item">
              <dt>{item.question}</dt>
              <dd>{item.answer}</dd>
            </div>
          ))}
        </dl>
      </section>
    )
  }

  <RelatedPages related={data.related} />

  {
    data.cta ? (
      <CloudCta
        heading={data.title}
        body={data.metaDescription}
        href={data.cta.href}
        label={data.cta.label}
      />
    ) : (
      <CloudCta />
    )
  }
</article>
