---
import { connectors, connectorCategories } from '../generated/connectors';

const haystack = (c: (typeof connectors)[number]) =>
  [c.name, c.tagline, c.categoryLabel, ...c.keywords].join(' ').toLowerCase();
---

<div class="connector-catalog" data-connector-catalog>
  <div class="catalog-search">
    <svg
      class="catalog-search-icon"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      type="search"
      class="catalog-search-input"
      placeholder="Search connectors by name, vendor, or resource…"
      aria-label="Search connectors"
      autocomplete="off"
      data-catalog-input
    />
  </div>

  <div class="catalog-filters" role="group" aria-label="Filter by category">
    <button
      type="button"
      class="catalog-chip is-active"
      data-category-filter=""
      aria-pressed="true"
    >
      All <span class="catalog-chip-count">{connectors.length}</span>
    </button>
    {
      connectorCategories.map((cat) => (
        <button
          type="button"
          class="catalog-chip"
          data-category-filter={cat.id}
          aria-pressed="false"
        >
          {cat.label} <span class="catalog-chip-count">{cat.count}</span>
        </button>
      ))
    }
  </div>

  <p class="catalog-count" data-catalog-count aria-live="polite"></p>

  <div class="catalog-grid">
    {
      connectors.map((c) => (
        <a
          class="catalog-card"
          href={c.href}
          data-connector-card
          data-category={c.category}
          data-search={haystack(c)}
        >
          <span class="catalog-card-icon" style="background:#ffffff;">
            <img src={c.iconPath} alt={`${c.name} logo`} width="28" height="28" loading="lazy" />
          </span>
          <span class="catalog-card-body">
            <span class="catalog-card-head">
              <span class="catalog-card-name">{c.name}</span>
              <span class="catalog-card-category">{c.categoryLabel}</span>
            </span>
            <span class="catalog-card-tagline">{c.tagline}</span>
          </span>
        </a>
      ))
    }
  </div>

  <p class="catalog-empty" data-catalog-empty hidden>
    No connectors match your search.
  </p>
</div>

<style>
  .connector-catalog {
    margin: 1.5rem 0 2rem;
  }
  .catalog-search {
    position: relative;
    display: flex;
    align-items: center;
  }
  .catalog-search-icon {
    position: absolute;
    left: 0.75rem;
    color: var(--sl-color-gray-3);
    pointer-events: none;
  }
  .catalog-search-input {
    width: 100%;
    padding: 0.6rem 0.75rem 0.6rem 2.25rem;
    font-size: var(--sl-text-base);
    color: var(--sl-color-white);
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
  }
  .catalog-search-input:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 1px var(--sl-color-accent);
  }
  .catalog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .catalog-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.7rem;
    font-size: var(--sl-text-sm);
    line-height: 1.2;
    color: var(--sl-color-gray-2);
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    cursor: pointer;
  }
  .catalog-chip:hover {
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }
  .catalog-chip.is-active {
    color: var(--sl-color-black);
    background: var(--sl-color-white);
    border-color: var(--sl-color-white);
    font-weight: 600;
  }
  .catalog-chip-count {
    font-size: var(--sl-text-xs);
    opacity: 0.7;
  }
  .catalog-count {
    margin: 1rem 0 0.5rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
  }
  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 0.75rem;
  }
  .catalog-card {
    display: flex;
    gap: 0.75rem;
    padding: 0.9rem;
    text-decoration: none;
    color: var(--sl-color-white);
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.6rem;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
  }
  .catalog-card:hover {
    border-color: var(--sl-color-accent);
    transform: translateY(-2px);
  }
  .catalog-card[hidden] {
    display: none;
  }
  .catalog-card-icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.45rem;
    box-sizing: border-box;
    padding: 0.35rem;
  }
  .catalog-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .catalog-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .catalog-card-name {
    font-weight: 600;
    font-size: var(--sl-text-base);
  }
  .catalog-card-category {
    flex: none;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .catalog-card-tagline {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    line-height: 1.4;
  }
  .catalog-empty {
    margin-top: 1rem;
    color: var(--sl-color-gray-3);
  }
</style>

<script>
  function normalize(value: string): string {
    return value.trim().toLowerCase();
  }

  for (const root of document.querySelectorAll<HTMLElement>(
    '[data-connector-catalog]',
  )) {
    const input = root.querySelector<HTMLInputElement>('[data-catalog-input]');
    const chips = [
      ...root.querySelectorAll<HTMLButtonElement>('[data-category-filter]'),
    ];
    const cards = [
      ...root.querySelectorAll<HTMLAnchorElement>('[data-connector-card]'),
    ];
    const count = root.querySelector<HTMLElement>('[data-catalog-count]');
    const empty = root.querySelector<HTMLElement>('[data-catalog-empty]');

    let category = '';
    let query = '';

    const apply = () => {
      let visible = 0;
      for (const card of cards) {
        const matchesCategory =
          !category || card.dataset.category === category;
        const matchesQuery =
          !query || (card.dataset.search ?? '').includes(query);
        const show = matchesCategory && matchesQuery;
        card.hidden = !show;
        if (show) {
          visible += 1;
        }
      }
      if (empty) {
        empty.hidden = visible > 0;
      }
      if (count) {
        count.textContent =
          visible === cards.length
            ? `${cards.length} connectors`
            : `${visible} of ${cards.length} connectors`;
      }
    };

    input?.addEventListener('input', () => {
      query = normalize(input.value);
      apply();
    });

    for (const chip of chips) {
      chip.addEventListener('click', () => {
        category = chip.dataset.categoryFilter ?? '';
        for (const other of chips) {
          const active = other === chip;
          other.classList.toggle('is-active', active);
          other.setAttribute('aria-pressed', String(active));
        }
        apply();
      });
    }

    apply();
  }
</script>
