---
import ContentLayout from '../../layouts/ContentLayout.astro';
import ContentList from '../../components/content/ContentList.astro';
import { getSectionEntries } from '../../lib/content';
import { SECTIONS } from '../../lib/sections';

const section = SECTIONS.alternatives;
const entries = await getSectionEntries(section.pageType);

if (entries.length === 0) {
  return new Response(null, { status: 404 });
}
---

<ContentLayout
  title={`${section.title} — Rawdash`}
  description={section.description}
  path={section.basePath}
>
  <ContentList
    label={section.label}
    title={section.title}
    description={section.description}
    basePath={section.basePath}
    entries={entries}
  />
</ContentLayout>
