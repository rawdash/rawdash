---
import { connectors } from '../generated/connectors';
import Analytics from '../components/Analytics.astro';
import SiteNav from '../components/site/SiteNav.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import {
  faqPageJsonLd,
  serializeJsonLd,
  softwareApplicationJsonLd,
} from '../lib/seo';
import '../styles/landing.css';

const FEATURED_CONNECTOR_IDS = [
  'github-actions',
  'linear',
  'jira',
  'sentry',
  'datadog',
  'stripe',
  'google-analytics',
  'hubspot',
  'salesforce',
  'openai',
  'vercel',
  'intercom',
];
const connectorById = new Map(connectors.map((c) => [c.id, c]));
const featuredConnectors = FEATURED_CONNECTOR_IDS.map((id) => {
  const connector = connectorById.get(id);
  if (!connector) {
    throw new Error(`Unknown FEATURED_CONNECTOR_ID: ${id}`);
  }
  return connector;
});

const PRODUCT_DESCRIPTION =
  'Open-source headless dashboard backend. Pre-built connectors, background ' +
  'sync, and a clean API your frontend can consume.';

const faqs = [
  {
    question: 'What is Rawdash?',
    answer:
      'Rawdash is an open-source headless dashboard backend. It syncs data ' +
      'from your SaaS tools on a schedule, caches it locally, and exposes it ' +
      'through a typed query API — so you can build dashboards without writing ' +
      'glue code.',
  },
  {
    question: 'Is Rawdash free and open source?',
    answer:
      'Yes. Rawdash is licensed under Apache 2.0 and free to self-host. ' +
      'Rawdash Cloud is an optional managed offering for teams that want ' +
      'hosting, automatic syncs, and a hosted dashboard UI without running ' +
      'infrastructure.',
  },
  {
    question: 'How is Rawdash different from a BI tool like Metabase or Looker?',
    answer:
      'Rawdash is headless: it has no opinion about your UI. Instead of ' +
      'shipping charts, it gives you a framework-agnostic API that any ' +
      'frontend — Next.js, Remix, or a plain HTTP client — can consume. You ' +
      'bring your own UI and run it anywhere.',
  },
  {
    question: 'Do I have to host Rawdash myself?',
    answer:
      'No. You can self-host the open-source packages anywhere that runs ' +
      'Node.js, or use Rawdash Cloud for managed hosting with no infra to ' +
      'maintain.',
  },
  {
    question: 'Which data sources does Rawdash support?',
    answer:
      'Rawdash ships with pre-built connectors such as GitHub, with more ' +
      'added regularly. Each connector defines its own data shape, sync ' +
      'schedule, and retention policy, and you can author your own using the ' +
      'connector guide.',
  },
];

const jsonLd = [
  softwareApplicationJsonLd(PRODUCT_DESCRIPTION),
  faqPageJsonLd(faqs),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Rawdash — Headless dashboard backend for any team</title>
    <meta name="description" content={PRODUCT_DESCRIPTION} />
    {
      jsonLd.map((block) => (
        <script type="application/ld+json" set:html={serializeJsonLd(block)} />
      ))
    }
    <Analytics />
  </head>
  <body>
    <SiteNav />

    <!-- Hero -->
    <div class="hero-band">
    <section class="hero">
      <div class="hero-badge">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" focusable="false">
          <circle cx="6" cy="6" r="5" stroke="#a78bfa" stroke-width="1.5"/>
          <circle cx="6" cy="6" r="2" fill="#a78bfa"/>
        </svg>
        Open Source · Apache 2.0
      </div>
      <h1>Headless dashboard backend<br/>for any team</h1>
      <p>
        Pre-built connectors for your SaaS tools, background sync, and a clean
        API your frontend can consume. Bring your own UI. Run it anywhere.
      </p>
      <div class="hero-actions">
        <a href="/docs/getting-started" class="btn-primary">
          Get Started →
        </a>
        <a href="https://github.com/rawdash/rawdash" class="btn-secondary">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
      </div>
      <div class="install-snippet">
        <span class="prompt">$</span>
        <span class="cmd">npm install @rawdash/core @rawdash/server @rawdash/hono @hono/node-server @rawdash/connector-github @rawdash/adapter-turso</span>
      </div>
    </section>
    </div>

    <!-- What it is -->
    <div class="band-alt">
    <section class="section">
      <p class="section-label">What is Rawdash?</p>
      <h2 class="section-title">The data layer your dashboards deserve</h2>
      <p class="section-subtitle">
        Stop writing glue code between your SaaS tools and your dashboard UI.
        Rawdash handles the sync, caching, and querying — you ship the product.
      </p>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🔌</div>
          <h3>Pre-built connectors</h3>
          <p>GitHub and more. Each connector defines its own data shape, sync schedule, and retention policy.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Background sync engine</h3>
          <p>Data is fetched and cached automatically. Your frontend always queries fresh, pre-computed results.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🗄️</div>
          <h3>Pluggable storage</h3>
          <p>Ship with the built-in Turso (libSQL) adapter or bring your own. The storage interface is tiny by design.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎨</div>
          <h3>Framework-agnostic API</h3>
          <p>Works with Next.js, Remix, Express, or any HTTP server. Mount a single route handler and you're done.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🤖</div>
          <h3>MCP-ready</h3>
          <p>First-class Model Context Protocol support. Wire up Claude Code and Claude Desktop in minutes.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📦</div>
          <h3>TypeScript-first</h3>
          <p>Full end-to-end type safety from connector definitions through to your frontend queries.</p>
        </div>
      </div>
    </section>
    </div>

    <!-- How it works -->
    <section class="section">
      <p class="section-label">How it works</p>
      <h2 class="section-title">Three steps to a working dashboard backend</h2>
      <p class="section-subtitle">
        Define your config, mount the handler, query from your frontend.
      </p>
      <div class="code-block">
        <div class="code-block-header">
          <span>📄</span>
          rawdash.config.ts
        </div>
        <pre><code><span class="kw">import</span> &#123; <span class="fn">serve</span> <span class="kw">as</span> <span class="fn">honoServe</span> &#125; <span class="kw">from</span> <span class="str">'@hono/node-server'</span>;
<span class="kw">import</span> &#123; <span class="fn">defineConfig</span>, <span class="fn">defineDashboard</span> &#125; <span class="kw">from</span> <span class="str">'@rawdash/core'</span>;
<span class="kw">import</span> &#123; <span class="fn">GitHubConnector</span> &#125; <span class="kw">from</span> <span class="str">'@rawdash/connector-github'</span>;
<span class="kw">import</span> &#123; <span class="fn">TursoStorage</span> &#125; <span class="kw">from</span> <span class="str">'@rawdash/adapter-turso'</span>;
<span class="kw">import</span> &#123; <span class="fn">mountEngine</span> &#125; <span class="kw">from</span> <span class="str">'@rawdash/hono'</span>;

<span class="kw">const</span> github = <span class="kw">new</span> <span class="fn">GitHubConnector</span>(&#123;
  token: process.env.<span class="fn">GITHUB_TOKEN</span>,
&#125;);

<span class="kw">const</span> &#123; app &#125; = <span class="fn">mountEngine</span>(<span class="fn">defineConfig</span>(&#123;
  connectors: [&#123; connector: github &#125;],
  dashboards: &#123;
    <span class="str">'eng-health'</span>: <span class="fn">defineDashboard</span>(&#123; widgets: &#123;&#125; &#125;),
  &#125;,
&#125;), &#123; storage: <span class="kw">new</span> <span class="fn">TursoStorage</span>(&#123; url: process.env.<span class="fn">TURSO_URL</span> &#125;) &#125;);
<span class="fn">honoServe</span>(&#123; fetch: app.fetch, port: 8080 &#125;);</code></pre>
      </div>
    </section>

    <!-- Connectors -->
    <div class="band-alt">
    <section class="section">
      <p class="section-label">Connectors</p>
      <h2 class="section-title">Your tools, pre-wired</h2>
      <p class="section-subtitle">
        Each connector syncs data on a schedule, stores it locally, and exposes
        it through a typed query interface.
      </p>
      <div class="connectors-grid">
        {
          featuredConnectors.map((c) => (
            <a class="connector-card available" href={c.href}>
              <div class="connector-icon" style="background:#ffffff;">
                <img
                  src={c.iconPath}
                  alt={`${c.name} logo`}
                  width="26"
                  height="26"
                  loading="lazy"
                />
              </div>
              <span class="connector-name">{c.name}</span>
              <span class="connector-badge badge-available">Available</span>
            </a>
          ))
        }
        <a class="connector-card" href="/docs/connectors">
          <div class="connector-icon connector-icon--ghost">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z" />
            </svg>
          </div>
          <span class="connector-name">View all {connectors.length} connectors</span>
          <span class="connector-badge badge-soon">Browse →</span>
        </a>
        <a class="connector-card" href="/docs/connector-guide">
          <div class="connector-icon connector-icon--ghost">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
          </div>
          <span class="connector-name">Build your own</span>
          <span class="connector-badge badge-soon">Guide</span>
        </a>
      </div>
    </section>
    </div>

    <!-- FAQ -->
    <section class="section">
      <p class="section-label">FAQ</p>
      <h2 class="section-title">Questions, answered</h2>
      <div class="faq-list" data-faq>
        {
          faqs.map((faq, i) => (
            <div class="faq-item">
              <button
                type="button"
                class="faq-question"
                id={`faq-q-${i}`}
                aria-expanded="false"
                aria-controls={`faq-a-${i}`}
              >
                <span>{faq.question}</span>
                <span class="faq-icon" aria-hidden="true" />
              </button>
              <div
                class="faq-answer"
                id={`faq-a-${i}`}
                role="region"
                aria-labelledby={`faq-q-${i}`}
              >
                <div class="faq-answer-inner">
                  <p>{faq.answer}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- CTA Banner -->
    <div class="cta-banner">
      <div class="cta-inner">
        <div>
          <h2>Try Rawdash Cloud</h2>
          <p>Managed hosting, automatic syncs, and a hosted dashboard UI — no infra required.</p>
        </div>
        <a href="https://cloud.rawdash.dev" class="btn-primary">
          Go to Cloud ↗
        </a>
      </div>
    </div>

    <SiteFooter />

    <script>
      for (const root of document.querySelectorAll('[data-faq]')) {
        const items = [...root.querySelectorAll('.faq-item')];
        for (const item of items) {
          const button = item.querySelector('.faq-question');
          button?.addEventListener('click', () => {
            const willOpen = !item.classList.contains('open');
            for (const other of items) {
              other.classList.remove('open');
              other
                .querySelector('.faq-question')
                ?.setAttribute('aria-expanded', 'false');
            }
            if (willOpen) {
              item.classList.add('open');
              button.setAttribute('aria-expanded', 'true');
            }
          });
        }
      }
    </script>
  </body>
</html>
