---
import SiteNav from '../components/site/SiteNav.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import Analytics from '../components/Analytics.astro';
import { canonical, serializeJsonLd } from '../lib/seo';
import '../styles/landing.css';
import '../styles/content.css';

interface Props {
  /** `<title>` text. */
  title: string;
  /** Meta description. */
  description: string;
  /** Site-absolute path for the canonical URL, e.g. `/blog/my-post`. */
  path: string;
  /** Open Graph type. */
  ogType?: 'website' | 'article';
  /** JSON-LD blocks to embed in <head>. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  path,
  ogType = 'website',
  jsonLd = [],
} = Astro.props;

const canonicalUrl = canonical(path, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Rawdash" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {
      jsonLd.map((block) => (
        <script type="application/ld+json" set:html={serializeJsonLd(block)} />
      ))
    }
    <Analytics />
  </head>
  <body>
    <SiteNav />
    <slot />
    <SiteFooter />
  </body>
</html>
