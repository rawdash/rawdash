# GitHub personal access token (required by the local dev rawdash server)
GITHUB_TOKEN=

# GitHub repo to pull CI data from (defaults to rawdash/rawdash)
GITHUB_OWNER=rawdash
GITHUB_REPO=rawdash

# Local dev rawdash server port (default: 8080)
PORT=8080

# Base URL the browser uses to reach the rawdash API. In production the app is a
# static export served by an external same-origin proxy, so this is left unset
# and defaults to the relative "/api". For local dev, point it at the local
# rawdash server started by `pnpm dev` (which serves with CORS enabled).
NEXT_PUBLIC_RAWDASH_PROXY_URL=http://localhost:8080
