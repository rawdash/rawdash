# GitHub personal access token (required for local dev)
GITHUB_TOKEN=

# GitHub repo to pull CI data from (defaults to rawdash/rawdash)
GITHUB_OWNER=rawdash
GITHUB_REPO=rawdash

# Rawdash API server port (default: 8080)
PORT=8080

# Rawdash API base URL. Point this at your local server (default), a self-hosted
# instance, or a hosted Rawdash service.
RAWDASH_URL=http://localhost:8080

# Optional bearer token sent on requests to RAWDASH_URL. Leave blank when running
# against a local server that doesn't require auth.
RAWDASH_API_KEY=
