# GitHub personal access token (required for local dev)
GITHUB_TOKEN=

# GitHub repo to pull CI data from (defaults to rawdash/rawdash)
GITHUB_OWNER=rawdash
GITHUB_REPO=rawdash

# Rawdash API server port (default: 8080)
PORT=8080

# Rawdash API URL used by the Next.js app in local dev (should match PORT above)
RAWDASH_URL=http://localhost:8080

# Set to 'cloud' to proxy widget requests to the cloud API instead of local server
RAWDASH_MODE=

# Cloud API base URL — required when RAWDASH_MODE=cloud
RAWDASH_CLOUD_URL=

# Cloud API key — required when RAWDASH_MODE=cloud
RAWDASH_API_KEY=
