{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@rawdash/core": ["../../packages/core/src/index.ts"],
      "@rawdash/nextjs": ["../../packages/nextjs/src/index.ts"],
      "@rawdash/server": ["../../packages/server/src/index.ts"],
      "@rawdash/connector-github": [
        "../../packages/connectors/github/src/index.ts"
      ]
    },
    "noEmit": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
