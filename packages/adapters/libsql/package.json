{
  "name": "@rawdash/adapter-libsql",
  "version": "0.27.0",
  "description": "Rawdash libSQL/Turso storage adapter",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rawdash/rawdash.git",
    "directory": "packages/adapters/libsql"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "@rawdash/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "db:bundle": "npx tsx scripts/bundle-migrations.ts",
    "db:generate": "drizzle-kit generate && pnpm db:bundle"
  },
  "dependencies": {
    "@rawdash/core": "workspace:*",
    "kysely": "^0.29.0",
    "kysely-libsql": "^0.7.0"
  },
  "peerDependencies": {
    "@libsql/client": ">=0.14.0 <1.0.0"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.0",
    "@types/node": "^22.19.17",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.38.4",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
