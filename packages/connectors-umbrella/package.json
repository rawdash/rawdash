{
  "name": "@rawdash/connectors",
  "version": "0.18.0",
  "description": "Umbrella package aggregating every built-in Rawdash connector. Depend on this one package instead of N individual @rawdash/connector-* packages.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rawdash/rawdash.git",
    "directory": "packages/connectors-umbrella"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    "./metadata": {
      "@rawdash/source": "./src/metadata.ts",
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js"
    },
    "./registry": {
      "@rawdash/source": "./src/registry.ts",
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@rawdash/connector-aws-cloudwatch": "workspace:*",
    "@rawdash/connector-aws-cost": "workspace:*",
    "@rawdash/connector-datadog": "workspace:*",
    "@rawdash/connector-gcp-billing": "workspace:*",
    "@rawdash/connector-gcp-monitoring": "workspace:*",
    "@rawdash/connector-github": "workspace:*",
    "@rawdash/connector-gitlab": "workspace:*",
    "@rawdash/connector-google-ads": "workspace:*",
    "@rawdash/connector-google-analytics": "workspace:*",
    "@rawdash/connector-google-search-console": "workspace:*",
    "@rawdash/connector-hubspot": "workspace:*",
    "@rawdash/connector-intercom": "workspace:*",
    "@rawdash/connector-jira": "workspace:*",
    "@rawdash/connector-launchdarkly": "workspace:*",
    "@rawdash/connector-linear": "workspace:*",
    "@rawdash/connector-meta-ads": "workspace:*",
    "@rawdash/connector-mixpanel": "workspace:*",
    "@rawdash/connector-new-relic": "workspace:*",
    "@rawdash/connector-posthog": "workspace:*",
    "@rawdash/connector-salesforce": "workspace:*",
    "@rawdash/connector-sentry": "workspace:*",
    "@rawdash/connector-stripe": "workspace:*",
    "@rawdash/connector-vercel": "workspace:*",
    "@rawdash/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
