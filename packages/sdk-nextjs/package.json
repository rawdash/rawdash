{
  "name": "@rawdash/sdk-nextjs",
  "version": "0.21.0",
  "description": "Rawdash client SDK for Next.js App Router (Server Components and Server Actions)",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rawdash/rawdash.git",
    "directory": "packages/sdk-nextjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "@rawdash/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "@rawdash/source": "./src/client.ts",
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./skeleton": {
      "@rawdash/source": "./src/skeleton.tsx",
      "types": "./dist/skeleton.d.ts",
      "import": "./dist/skeleton.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@rawdash/sdk-client": "workspace:*",
    "@rawdash/sdk-runtime": "workspace:*",
    "@rawdash/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2"
  }
}
